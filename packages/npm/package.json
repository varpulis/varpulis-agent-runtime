{
  "name": "@varpulis/agent-runtime",
  "version": "0.1.0",
  "description": "Real-time behavioral guardrails for AI agents",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "wasm/"
  ],
  "scripts": {
    "build:wasm": "wasm-pack build ../../crates/varpulis-agent-wasm --target bundler --out-dir ../../packages/npm/wasm",
