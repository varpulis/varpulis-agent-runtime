    "build": "npm run build:wasm && npm run build:ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "ai",
    "agent",
    "guardrails",
    "monitoring",
    "langchain",
    "mcp",
    "behavioral-patterns"
  ],
  "license": "Apache-2.0",
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
